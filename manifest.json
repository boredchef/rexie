{
  "name": "Rexie",
  "description": "a very motivational dinosaur",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["character.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/DinoSprites.png"],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.reddit.com/*"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["scripting", "activeTab", "tabGroups", "storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.reddit.com/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  }
}